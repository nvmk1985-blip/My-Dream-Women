{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "fuser -k 8080/tcp 2>/dev/null; sleep 1; export NODE_ENV=development && pnpm run build && pnpm run start:watch",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "start:watch": "while true; do node --enable-source-maps ./dist/index.mjs; echo '[auto-restart] Server exited — restarting in 3s...'; sleep 3; done",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.2.0",
    "@gradio/client": "^2.2.0",
    "@types/web-push": "^3.6.4",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "mammoth": "^1.8.0",
    "pino": "^9",
    "pino-http": "^10",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
